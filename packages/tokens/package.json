{
  "name": "@pharm/tokens",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./css": {
      "types": "./src/css/index.d.ts",
      "import": "./src/css/index.css"
    },
    "./scss": {
      "types": "./src/scss/variables.d.ts",
      "import": "./src/scss/_variables.scss"
    }
  },
  "scripts": {
    "build": "style-dictionary build --config style-dictionary.config.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint ."
  }
}
